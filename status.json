---
layout: null
permalink: /status.json
---
{% assign sorted = site.status_updates | sort: 'date' | reverse -%}
{
  "count": {{ sorted.size }},
  "items": [
    {%- for s in sorted -%}
    {
      "url": {{ s.url | jsonify }},
      "date_iso": {{ s.date | date_to_xmlschema | jsonify }},
      "date_unix": {{ s.date | date: '%s' | jsonify }},
      "date_display": {{ s.date | date: "%I:%M %p %B %-d, %Y %Z" | jsonify }},
      "source": {{ s.source | default: "" | jsonify }},
      "content_html": {{ s.content | markdownify | strip_newlines | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
